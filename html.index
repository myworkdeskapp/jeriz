<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday Jerizza</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,400&family=Montserrat:wght@100;300;600&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
    
    <style>
        :root {
            --gold: #d4af37;
            --soft-white: #faf9f6;
            --text: #2c2c2c;
            --accent-yellow: #f4d03f;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: var(--soft-white);
            color: var(--text);
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
        }

        /* --- Header Section --- */
        header {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            padding: 0 5%;
            background: linear-gradient(to bottom, rgba(250,249,246,0) 70%, rgba(250,249,246,1)),
                        url('https://images.unsplash.com/photo-1551632811-561732d1e306?auto=format&fit=crop&q=80&w=1200'); /* Hiking Background Placeholder */
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
        }

        .hero-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(10px);
            padding: 60px;
            text-align: center;
            border: 1px solid rgba(212, 175, 55, 0.3);
            box-shadow: 0 20px 50px rgba(0,0,0,0.1);
            max-width: 800px;
            animation: fadeIn 2s ease;
        }

        .name-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2.5rem, 8vw, 5rem);
            line-height: 1;
            margin-bottom: 10px;
            color: var(--text);
        }

        .age-badge {
            font-size: 1.5rem;
            color: var(--gold);
            letter-spacing: 3px;
            margin-bottom: 30px;
        }

        .small-note {
            font-size: 0.9rem;
            opacity: 0.6;
            vertical-align: middle;
            margin-left: 10px;
        }

        /* --- Message Theater (Cycles every 3s) --- */
        .message-theater {
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            margin-top: 20px;
        }

        .letter-segment {
            position: absolute;
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.8s ease;
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.6rem;
            font-style: italic;
            line-height: 1.5;
            width: 100%;
        }

        .letter-segment.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* --- Hiking Gallery Section --- */
        .gallery {
            padding: 100px 10%;
            text-align: center;
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 50px;
        }

        .photo-frame {
            height: 400px;
            background: #eee;
            overflow: hidden;
            position: relative;
            border-radius: 4px;
        }

        .photo-frame img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 1s ease;
        }

        .photo-frame:hover img {
            transform: scale(1.1);
        }

        .signature {
            margin-top: 50px;
            font-weight: 600;
            color: var(--gold);
            font-size: 1.2rem;
            letter-spacing: 5px;
        }

        /* --- Floating Hearts --- */
        .heart {
            position: fixed;
            color: var(--accent-yellow);
            font-size: 20px;
            z-index: -1;
            animation: floatUp 10s linear infinite;
        }

        @keyframes floatUp {
            0% { transform: translateY(110vh) rotate(0deg); opacity: 1; }
            100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }

        .timer-bar {
            width: 100px;
            height: 2px;
            background: #ddd;
            margin: 40px auto;
            position: relative;
        }

        .timer-progress {
            position: absolute;
            left: 0; width: 0%; height: 100%;
            background: var(--gold);
            animation: progress 3s linear infinite;
        }

        @keyframes progress {
            0% { width: 0%; }
            100% { width: 100%; }
        }

    </style>
</head>
<body onclick="celebrate()">

    <header>
        <div class="hero-card">
            <div class="age-badge">HAPPY 18TH <span class="small-note">( 31st )</span></div>
            <h1 class="name-title">Jerizza Lagdaan</h1>
            
            <div class="message-theater" id="theater">
                <!-- Text segments injected by JS -->
            </div>

            <div class="timer-bar">
                <div class="timer-progress"></div>
            </div>

            <div class="signature">WITH LOVE, JEL 💛</div>
        </div>
    </header>

    <section class="gallery">
        <h2 style="font-family: 'Cormorant Garamond'; font-size: 2.5rem;">To our hiking days & happy memories...</h2>
        <div class="gallery-grid">
            <div class="photo-frame">
                <img src="https://images.unsplash.com/photo-1501555088652-021faa106b9b?auto=format&fit=crop&q=80&w=800" alt="Mountain">
            </div>
            <div class="photo-frame" style="margin-top: 40px;">
                <img src="https://images.unsplash.com/photo-1526772662000-3f88f10405ff?auto=format&fit=crop&q=80&w=800" alt="Trail">
            </div>
            <div class="photo-frame">
                <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&q=80&w=800" alt="Summit">
            </div>
        </div>
    </section>

    <script>
        const letter = [
            "Happy Birthday! 🎉",
            "Bff, it’s been 2 years of us being best friends, and honestly, I wouldn’t trade it for anything.",
            "From our deep emotional talks to our happy memories, especially those hiking days...",
            "Every moment with you means so much to me. You’ve been my safe place.",
            "I see you. I know how much you’ve been struggling, even when you don’t show it.",
            "But despite everything, you still manage to lift others up with your strength.",
            "I’m proud of you for all your hard work and everything you continue to fight through.",
            "Wishing you a future that feels lighter, brighter, and full of peace and happiness.",
            "I’ll always be here for you, just like you’ve always been for me. 💛"
        ];

        const theater = document.getElementById('theater');
        let currentIndex = 0;

        // Create segments
        letter.forEach((text, i) => {
            const span = document.createElement('div');
            span.className = 'letter-segment';
            span.innerText = text;
            if (i === 0) span.classList.add('active');
            theater.appendChild(span);
        });

        const segments = document.querySelectorAll('.letter-segment');

        function rotateMessage() {
            segments[currentIndex].classList.remove('active');
            currentIndex = (currentIndex + 1) % segments.length;
            segments[currentIndex].classList.add('active');
            
            // Randomly fire confetti on the first and last slide
            if(currentIndex === 0 || currentIndex === segments.length - 1) {
                celebrate();
            }
        }

        setInterval(rotateMessage, 3000);

        // Floating Hearts Generator
        function createHeart() {
            const heart = document.createElement('div');
            heart.className = 'heart';
            heart.innerHTML = '💛';
            heart.style.left = Math.random() * 100 + 'vw';
            heart.style.animationDuration = (Math.random() * 5 + 5) + 's';
            heart.style.fontSize = (Math.random() * 20 + 10) + 'px';
            document.body.appendChild(heart);
            setTimeout(() => heart.remove(), 10000);
        }
        setInterval(createHeart, 800);

        function celebrate() {
            confetti({
                particleCount: 100,
                spread: 70,
                origin: { y: 0.6 },
                colors: ['#d4af37', '#f4d03f', '#ffffff']
            });
        }
    </script>
</body>
</html>
